# ─── LLM Provider ───────────────────────────────
# Google Gemini API key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_api_key_here
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# ─── Agent Settings ─────────────────────────────
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_RETRIES=1

# ─── MCP Integrations ───────────────────────────
# Set to false to use real MCP servers (requires tokens below)
MCP_DEMO_MODE=true

# GitHub Personal Access Token
GITHUB_TOKEN=
GITHUB_REPO=antigravity/payment-service

# Google Workspace MCP Token (for Gmail, Drive, Calendar)
GOOGLE_MCP_TOKEN=

# ─── Output Settings ────────────────────────────
OUTPUT_DIR=./output
REPRO_DIR=./repro
LOG_DIR=./logs
LOG_LEVEL=INFO
